<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainContato"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F5F5F5"
    tools:context=".ContatoActivity">

    <TextView
        android:id="@+id/txtTituloContato"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Contato"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#263238"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/txtDescricaoContato"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Entre em contato com a administração de achados e perdidos."
        android:textSize="16sp"
        android:textColor="#546E7A"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enviar e-mail"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnTelefone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ligar para administração"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnVoltar"
        android:layout_width="190dp"
        android:layout_height="52dp"
        android:text="Voltar" />

</LinearLayout>