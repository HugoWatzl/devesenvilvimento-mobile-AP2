<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">


        <TextView
            android:id="@+id/txtTituloEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Editar Objeto"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#263238"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nome do objeto"
            android:textColor="#263238"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/editNomeEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex: Carteira, chave, celular"
            android:inputType="text"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Categoria"
            android:textColor="#263238"
            android:textSize="16sp" />

        <Spinner
            android:id="@+id/spinnerCategoriaEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textColor="#263238"
            android:textSize="16sp" />

        <RadioGroup
            android:id="@+id/radioStatusEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/radioPerdiEditar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perdi" />

            <RadioButton
                android:id="@+id/radioEncontreiEditar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Encontrei"
                android:layout_marginStart="16dp" />

        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Local"
            android:textColor="#263238"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/editLocalEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex: Cantina, sala 302, bloco A"
            android:inputType="text"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descrição"
            android:textColor="#263238"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/editDescricaoEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex: Carteira preta com zíper"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnSalvarEdicao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Salvar Alterações" />

        <Button
            android:id="@+id/btnVoltarEditar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voltar"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</ScrollView>