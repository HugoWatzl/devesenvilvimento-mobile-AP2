<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainListagem"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="90dp"
    android:paddingBottom="16dp"
    android:background="#F5F5F5"
    tools:context=".ListagemActivity">

    <TextView
        android:id="@+id/txtTituloLista"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Objetos achados"
        android:textColor="#263238"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnNovoObjeto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cadastrar Objeto" />

        <Button
            android:id="@+id/btnContato"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Contato"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBarLista"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txtListaVazia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nenhum objeto cadastrado ainda."
        android:textColor="#78909C"
        android:textSize="16sp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="24dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerObjetos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        tools:listitem="@layout/item_objeto" />

</LinearLayout>